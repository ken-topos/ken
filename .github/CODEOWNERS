# Ken code ownership. CODEOWNERS routes domain review to the owning team; the
# Architect (design/correctness) and Integrator (gate + merge) are required
# reviewers — listed on each line because GitHub uses only the last-matching
# pattern per file, so required reviewers don't union across patterns.
#
# PLACEHOLDER: these teams/roles must exist under the ken-topos org (WP F1).
# Models per role are in /agent/MODELS.md.

# Code crates: owning build team + Architect + Integrator
/crates/ken-kernel/      @ken-topos/team-kernel     @ken-topos/architect @ken-topos/integration
/crates/ken-elaborator/  @ken-topos/team-verify     @ken-topos/architect @ken-topos/integration
/crates/ken-prover/      @ken-topos/team-verify     @ken-topos/architect @ken-topos/integration
/crates/ken-lang/        @ken-topos/team-language   @ken-topos/architect @ken-topos/integration
/crates/ken-interp/      @ken-topos/team-runtime    @ken-topos/architect @ken-topos/integration
/crates/ken-cli/         @ken-topos/team-runtime    @ken-topos/architect @ken-topos/integration
# (Ergo team's crates added when they exist, e.g. /crates/ken-repl/)

# Spec enclave (clean-room): Spec team + Integrator
/spec/                   @ken-topos/team-spec       @ken-topos/integration
/conformance/            @ken-topos/team-spec       @ken-topos/integration

# Docs: Librarian + Integrator; ADRs additionally owned by Foundation
/docs/                   @ken-topos/librarian       @ken-topos/integration
/docs/adr/               @ken-topos/team-foundation @ken-topos/integration

# Workflow corpus: Steward owns (promotion + topology guard) + Integrator merges
/agent/                  @ken-topos/steward         @ken-topos/integration

# Everything else: Architect + Integrator
*                        @ken-topos/architect       @ken-topos/integration
