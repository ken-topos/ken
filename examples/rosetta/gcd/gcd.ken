-- ── Oracle ───────────────────────────────────────────────────────────────────

-- main: gcd(12, 8) = 4 (not printed via IO -- see GAP-natToDecimal-
-- wholeprogram above; this evaluates the real GCD algorithm correctly,
-- just returns the value rather than driving Console output).
view main : Int = natToInt (natGcd twelve eight)
