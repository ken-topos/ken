-- Rosetta Code: FizzBuzz
-- https://rosettacode.org/wiki/FizzBuzz
--
-- Task: for n = 1..20, print "FizzBuzz" if n is divisible by 15,
-- "Fizz" if divisible by 3, "Buzz" if divisible by 5, else print n.
--
-- VAL2 status update -- all originally-documented gaps are now CLOSED:
-- `GAP-io-surface` (`print_line`/`ken run` Console execution landed),
-- `GAP-bool-match` (`Bool` is directly `match`able), `GAP-string-literals`
-- (FIXED, VAL1-surface), and `GAP-natToDecimal-range` (the `Plain` case's
-- decimal printing was blocked pending `wp/RTP1-interp-sharing`'s
-- eager-IH-computation fix -- resolved, `e88ffa8`). `GAP-nested-patterns`
-- still holds (the reason for the `Mod3`/`Mod5` modular-accumulator
-- workaround below, kept as-is) but was never blocking, just an
-- ergonomic workaround. The IO loop over 1..20 reuses the `Vis`-under-
-- closure recursive combinator shape confirmed SCT-acceptable by VAL2's
-- own `printLoop` probe.
-- Classification result.
data FizzTag =
  Plain
  | IsFizz
  | IsBuzz
  | IsFizzBuzz

-- Helper: is a Nat zero?
data IsZero =
  Zero_
  | NonZero_

fn isZero (n : Nat) : IsZero =
  match n {
    Zero ↦ Zero_;
    Suc m ↦ NonZero_
  }

-- ── mod3 ──────────────────────────────────────────────────────────────────────
-- Modular accumulator for mod3: a 3-element cycle type avoids nested patterns
-- and mutual recursion. `mod3Step n acc` steps n times from acc.
data Mod3 =
  Zero3
  | One3
  | Two3

fn incMod3 (x : Mod3) : Mod3 =
  match x {
    Zero3 ↦ One3;
    One3 ↦ Two3;
    Two3 ↦ Zero3
  }

fn isZeroMod3 (x : Mod3) : IsZero =
  match x {
    Zero3 ↦ Zero_;
    One3 ↦ NonZero_;
    Two3 ↦ NonZero_
  }

fn mod3Step (n : Nat) (acc : Mod3) : Mod3 =
  match n {
    Zero ↦ acc;
    Suc m ↦
      mod3Step
        m
        (incMod3 acc)
  }

fn mod3 (n : Nat) : Mod3 = mod3Step n Zero3

-- ── mod5 ──────────────────────────────────────────────────────────────────────
-- Same pattern with a 5-element cycle type.
data Mod5 =
  Zero5
  | One5
  | Two5
  | Three5
  | Four5

fn incMod5 (x : Mod5) : Mod5 =
  match x {
    Zero5 ↦ One5;
    One5 ↦ Two5;
    Two5 ↦ Three5;
    Three5 ↦ Four5;
    Four5 ↦ Zero5
  }

fn isZeroMod5 (x : Mod5) : IsZero =
  match x {
    Zero5 ↦ Zero_;
    One5 ↦ NonZero_;
    Two5 ↦ NonZero_;
    Three5 ↦ NonZero_;
    Four5 ↦ NonZero_
  }

fn mod5Step (n : Nat) (acc : Mod5) : Mod5 =
  match n {
    Zero ↦ acc;
    Suc m ↦
      mod5Step
        m
        (incMod5 acc)
  }

fn mod5 (n : Nat) : Mod5 = mod5Step n Zero5

-- ── classify ─────────────────────────────────────────────────────────────────
fn classify (n : Nat) : FizzTag =
  match isZeroMod3 (mod3 n) {
    Zero_ ↦
      match isZeroMod5 (mod5 n) {
        Zero_ ↦ IsFizzBuzz;
        NonZero_ ↦ IsFizz
      };
    NonZero_ ↦
      match isZeroMod5 (mod5 n) {
        Zero_ ↦ IsBuzz;
        NonZero_ ↦ Plain
      }
  }

-- ── Decimal printing (`natToDecimal`, `ken-interp` has no `div_int`/
-- `mod_int`) ──────────────────────────────────────────────────────────────────
fn natAdd (a : Nat) (b : Nat) : Nat =
  match a {
    Zero ↦ b;
    Suc m ↦ Suc (natAdd m b)
  }

fn natToInt (n : Nat) : Int =
  match n {
    Zero ↦ 0 : Int;
    Suc m ↦ (1 : Int) + natToInt m
  }

fn list_append (a : Type) (xs : List a) (ys : List a) : List a =
  match xs {
    Nil ↦ ys;
    Cons x xs2 ↦
      Cons
        a
        x
        (list_append a xs2 ys)
  }

fn concat (a : String) (b : String) : String =
  list_char_to_string (list_append Char (string_to_list_char a) (string_to_list_char b))

fn sub10 (n : Nat) : Option Nat =
  match n {
    Zero ↦ None Nat;
    Suc n1 ↦
      match n1 {
        Zero ↦ None Nat;
        Suc n2 ↦
          match n2 {
            Zero ↦ None Nat;
            Suc n3 ↦
              match n3 {
                Zero ↦ None Nat;
                Suc n4 ↦
                  match n4 {
                    Zero ↦ None Nat;
                    Suc n5 ↦
                      match n5 {
                        Zero ↦ None Nat;
                        Suc n6 ↦
                          match n6 {
                            Zero ↦ None Nat;
                            Suc n7 ↦
                              match n7 {
                                Zero ↦ None Nat;
                                Suc n8 ↦
                                  match n8 {
                                    Zero ↦ None Nat;
                                    Suc n9 ↦
                                      match n9 {
                                        Zero ↦ None Nat;
                                        Suc n10 ↦
                                          Some
                                            Nat
                                            n10
                                      }
                                  }
                              }
                          }
                      }
                  }
              }
          }
      }
  }

fn mod10Fueled (fuel : Nat) (n : Nat) : Nat =
  match fuel {
    Zero ↦ n;
    Suc f ↦
      match sub10 n {
        None ↦ n;
        Some n2 ↦
          mod10Fueled
            f
            n2
      }
  }

fn mod10 (n : Nat) : Nat = mod10Fueled n n

fn div10Fueled (fuel : Nat) (n : Nat) (q : Nat) : Nat =
  match fuel {
    Zero ↦ q;
    Suc f ↦
      match sub10 n {
        None ↦ q;
        Some n2 ↦
          div10Fueled
            f
            n2
            (Suc q)
      }
  }

fn div10 (n : Nat) : Nat = div10Fueled n n Zero

fn digitChar (d : Nat) : String =
  list_char_to_string (Cons Char ((48 : Int) + natToInt d) (Nil Char))

fn natToDecimalFueled (fuel : Nat) (n : Nat) : String =
  match fuel {
    Zero ↦ digitChar n;
    Suc f ↦
      match div10 n {
        Zero ↦ digitChar (mod10 n);
        Suc q ↦
          concat
            (natToDecimalFueled f (Suc q))
            (digitChar (mod10 n))
      }
  }

fn natToDecimal (n : Nat) : String =
  match n {
    Zero ↦ "0";
    Suc m ↦
      natToDecimalFueled
        (Suc m)
        (Suc m)
  }

-- ── Output line + IO loop ────────────────────────────────────────────────────
fn fizzBuzzLine (n : Nat) : String =
  match classify n {
    IsFizz ↦ "Fizz";
    IsBuzz ↦ "Buzz";
    IsFizzBuzz ↦ "FizzBuzz";
    Plain ↦ natToDecimal n
  }

-- fizzBuzzLoop remaining current: prints `fizzBuzzLine current`, then
-- recurses `remaining - 1` times with `current + 1`. SCT: recursive call
-- on `r`, a strict `Suc`-sub-term of `remaining` -- same `Vis`-under-
-- closure recursive shape VAL2's own `printLoop` probe confirmed
-- SCT-acceptable.
--
-- `Vis`/`Ret` now take `ITree`'s 3 explicit params (State-effect-build lift,
-- VAL2 #10 / OQ-C.C2): `E=ConsoleOp`, `Resp=console_resp`, `R=Unit`.
proc fizzBuzzLoop (remaining : Nat) (current : Nat) : IO Unit visits [Console] =
  match remaining {
    Zero ↦
      Ret
        ConsoleOp
        console_resp
        Unit
        MkUnit;
    Suc r ↦
      Vis
        ConsoleOp
        console_resp
        Unit
        (Write
          Stdout
          (bytes_concat
            (bytes_encode (fizzBuzzLine current))
            (bytes_encode (list_char_to_string (Cons Char (10 : Int) (Nil Char))))))
        (λ_. fizzBuzzLoop r (Suc current))
  }

-- ── Oracle ───────────────────────────────────────────────────────────────────
-- main: fizzBuzzLine 1..20, one per line.
const twenty : Nat =
  Suc
    (Suc
      (Suc
        (Suc
          (Suc
            (Suc
              (Suc
                (Suc
                  (Suc
                    (Suc
                      (Suc
                        (Suc
                          (Suc
                            (Suc (Suc (Suc (Suc (Suc (Suc (Suc Zero)))))))))))))))))))

proc main
  (_input : ProcessInput)
  (_caps : ProgramCaps)
  : HostIO ExitCode
  visits [Console] =
  host_program (fizzBuzzLoop twenty (Suc Zero))
