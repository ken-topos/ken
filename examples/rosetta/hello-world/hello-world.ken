-- Rosetta Code: Hello world
-- https://rosettacode.org/wiki/Hello_world/Text
--
-- Task: print "Hello, World!" to standard output.
--
-- String literals (`37 §2.1`) and `print_line : String → IO Unit`
-- (`36 §2.1`) are both declared; `ken run` drives the Console effect
-- end-to-end (`42 §6`, wp/console-harvest-fix).
view main : IO Unit = print_line "Hello, World!"
