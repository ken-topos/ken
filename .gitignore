# Rust
/target/
**/*.rs.bk

# Editors / OS
.DS_Store
*.swp
.idea/
.vscode/

# Local env
.env
.env.local
.mootup
.moot/
# Belt-and-suspenders: never let a private key or a secrets dir into the repo.
*.pem
.secrets/
.worktrees/

# Local drop zone — put research notes, conversation transcripts, scratch files,
# and anything not meant for the public repo here. Everything in /local/ is
# gitignored except this folder's README.
/local/*
!/local/README.md

# scripts/gen-source-attestations.sh never writes the real ledger — only
# this proposed sibling, pending deliberate Librarian review (SRC-ATTEST).
library/SOURCE-ATTESTATIONS.proposed

# Keep Cargo.lock committed (this workspace ships a binary).

# Claude Code: ignore per-session state, but keep the role-skill corpus tracked
# and the shared project settings (fleet-wide hooks — see .claude/settings.json).
.claude/*
!.claude/skills/
!.claude/settings.json
