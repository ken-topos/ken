-- Lawful constructor-class tranche (CAT-1): the VALUE-LEVEL algebra half --
-- `Semigroup` and `Monoid` (spec/50-stdlib/55-lawful-functors.md). The
-- constructor classes `Functor`/`Foldable` (over `f : Type -> Type`) land in
-- this same package once the higher-kinded class-parameter extension does
-- (Architect's CAT-1 core ruling: `class C (f : Type -> Type)` needs a small
-- outer-ring elaborator extension) -- held here, not yet present.
--
-- No new kernel feature (AC1): a class is a record (33 SS5.2, right-nested
-- Sigma over 13 SS3); a law is an `Omega` proposition (16 SS1). Unlike
-- `Eq`/`Ord` (whose ops are `Bool`-valued, so their laws ride the
-- `IsTrue b := Equal Bool b True` bridge, 51 SS2), a Semigroup/Monoid
-- operation RETURNS an `a`, so its laws are the kernel's OWN propositional
-- equality `Equal a u v : Omega` directly -- an equation between `a`-values,
-- proof-irrelevant, no truncation (the 51 SS3 truncation catch never fires:
-- these are value equations, not a bare `\/`/`exists`).
--
-- Laws PROVED over inductive carriers, never postulated (AC3): the `List a`
-- append monoid by induction + `cong` (packages/transport), `Bool`'s
-- conjunction monoid by finite case-split. Zero `Axiom`, zero
-- `trusted_base()` delta -- every instance is a real `declare_def` record
-- value, kernel-re-checked.
--
-- Dependencies (derivation path, see MANIFEST): `cong`/`sym`/`trans`
-- (packages/transport/transport.ken, over the `J` former) for the inductive
-- congruence steps; `list_append` (packages/collections/collections.ken) as
-- the List monoid operation -- reused, never re-defined (subsume-don't-
-- proliferate).

-- ========================================================================
-- Semigroup -- an associative binary operation on `a`.
-- ========================================================================
-- `op` is the ergonomic `<>`/mappend, a plain identifier field (not an infix
-- token: a surface `<>` operator is deferred sugar, OQ-syntax -- exactly as
-- `36 SS4.5`'s `get`/`put` name the effect ops rather than minting operators).
-- `assoc` is a propositional equation in `Omega`.
class Semigroup a {
  op    : a â†’ a â†’ a ;
  assoc : (x : a) â†’ (y : a) â†’ (z : a) â†’ Equal a (op (op x y) z) (op x (op y z))
}

-- ========================================================================
-- Monoid -- a Semigroup with a two-sided identity `mempty`.
-- ========================================================================
-- Following the `DecEq`-subsumes-`Eq` precedent (51 SS2.2): the STRONGER
-- class RESTATES the weaker one's operation + law rather than wiring a
-- superclass field, and the subsumption -- "a Monoid yields a Semigroup by
-- forgetting `mempty`/`left_unit`/`right_unit`, keeping `op`/`assoc`" -- is
-- recorded as a FACT here, not a `where`-constraint. Same shape as Eq/Ord,
-- no new kind machinery. (Whether the CONSTRUCTOR-class chain of CAT-2
-- (Functor -> Applicative -> Monad) should instead WIRE superclass fields is
-- a template question for the Architect's higher-kinded lane -- flagged
-- there, not decided here.)
class Monoid a {
  op         : a â†’ a â†’ a ;
  mempty     : a ;
  assoc      : (x : a) â†’ (y : a) â†’ (z : a) â†’ Equal a (op (op x y) z) (op x (op y z)) ;
  left_unit  : (x : a) â†’ Equal a (op mempty x) x ;
  right_unit : (x : a) â†’ Equal a (op x mempty) x
}

-- ========================================================================
-- Instance 1 -- the `List` append monoid (the canonical inductive carrier).
-- ========================================================================
-- `op = list_append`, `mempty = Nil`. The three laws and the Monoid instance
-- are GENERIC in `a`: the CAT-1 D1 parametric-instance-head path elaborates
-- `instance Monoid (List a)` as `(a : Type) -> Monoid (List a)`, and the law
-- fields cite the existing generic `list_*` proofs rather than re-proving
-- them at a closed carrier.

-- Left unit is DEFINITIONAL: `list_append Nil x` iota-reduces to `x` by
-- append's first match arm, so the goal `Equal (List a) x x` stays
-- `Eq`-shaped over the neutral `x` -- closed by `Refl`.
fn list_left_unit (a : Type) (xs : List a)
  : Equal (List a) (list_append a (Nil a) xs) xs =
  Refl

-- Assoc is proved by induction on the first list. Base (`Nil`): both sides
-- reduce to the NEUTRAL `list_append a ys zs` -- still `Eq`-shaped, `Refl`.
-- Step (`Cons h t`): lift the tail IH under `Cons a h` with `cong`.
fn list_assoc (a : Type) (xs : List a) (ys : List a) (zs : List a)
  : Equal (List a) (list_append a (list_append a xs ys) zs)
                   (list_append a xs (list_append a ys zs)) =
  match xs {
    Nil â‡’ Refl ;
    Cons h t â‡’
      cong (List a) (List a)
        (list_append a (list_append a t ys) zs)
        (list_append a t (list_append a ys zs))
        (Cons a h)
        (list_assoc a t ys zs)
  }

-- Right unit is proved by induction on the list. Base (`Nil`): both sides
-- reduce to the CONSTRUCTOR `Nil a`, which observationally collapses to
-- `Top` (same nullary ctor, 16 SS8.1 / K7) -- so the goal is no longer
-- `Eq`-shaped and `Refl` does not apply; it is `Top`-introduced by `tt`.
-- (This is the exact `tt`-vs-`Refl` discrimination the `Bool` law proofs in
-- `lawful_classes.ken` document: constructor-headed endpoints -> `Top` ->
-- `tt`; neutral endpoints -> stuck `Eq` -> `Refl`.) Step (`Cons h t`): `cong`
-- under `Cons a h` on the tail IH.
fn list_right_unit (a : Type) (xs : List a)
  : Equal (List a) (list_append a xs (Nil a)) xs =
  match xs {
    Nil â‡’ tt ;
    Cons h t â‡’
      cong (List a) (List a)
        (list_append a t (Nil a))
        t
        (Cons a h)
        (list_right_unit a t)
  }

instance Semigroup (List Nat) {
  op    = list_append Nat ;
  assoc = list_assoc Nat
}

instance Monoid (List a) {
  op         = list_append a ;
  mempty     = Nil a ;
  assoc      = list_assoc a ;
  left_unit  = list_left_unit a ;
  right_unit = list_right_unit a
}

-- ========================================================================
-- Instance 2 -- the `Bool` conjunction monoid (the finite carrier).
-- ========================================================================
-- Complements the List monoid's inductive style with the FINITE case-split
-- style: no induction / no IH, every branch closes by `tt` or `Refl`
-- directly. `bool_and` is a transparent (match-based) `view`, NOT the
-- `and_bool` primitive -- deliberately, for the same reason `lawful_classes`
-- defines its own transparent `bool_or`: a primitive never reduces on a
-- symbolic argument (K1 `whnf` only unfolds `Decl::Transparent`), which would
-- make the laws unprovable; a transparent `bool_and` reduces on each concrete
-- constructor at zero kernel cost.
fn bool_and (p : Bool) (q : Bool) : Bool =
  match p { True â‡’ q ; False â‡’ False }

-- Associativity: full 2x2x2 case-split; each concrete branch reduces both
-- sides to the same literal, collapsing to `Top` -> `tt`.
fn band_assoc (x : Bool) (y : Bool) (z : Bool)
  : Equal Bool (bool_and (bool_and x y) z) (bool_and x (bool_and y z)) =
  match x {
    True â‡’ match y {
      True  â‡’ match z { True â‡’ tt ; False â‡’ tt } ;
      False â‡’ match z { True â‡’ tt ; False â‡’ tt }
    } ;
    False â‡’ match y {
      True  â‡’ match z { True â‡’ tt ; False â‡’ tt } ;
      False â‡’ match z { True â‡’ tt ; False â‡’ tt }
    }
  }

-- Left unit is DEFINITIONAL: `bool_and True x` reduces to `x` (first match
-- arm), goal `Equal Bool x x` neutral -> `Refl`.
fn band_left_unit (x : Bool) : Equal Bool (bool_and True x) x =
  Refl

-- Right unit needs the case-split (`bool_and x True` is stuck on symbolic
-- `x`): each branch reduces to a literal equal to itself -> `Top` -> `tt`.
fn band_right_unit (x : Bool) : Equal Bool (bool_and x True) x =
  match x { True â‡’ tt ; False â‡’ tt }

instance Semigroup Bool {
  op    = bool_and ;
  assoc = band_assoc
}

instance Monoid Bool {
  op         = bool_and ;
  mempty     = True ;
  assoc      = band_assoc ;
  left_unit  = band_left_unit ;
  right_unit = band_right_unit
}
